# 复制到 VPS：/etc/nginx/sites-available/yywtaylor.cyou
# 然后：sudo ln -s ... sites-enabled/ && sudo nginx -t && sudo systemctl reload nginx
#
# 证书：你已有 acme.sh 证书 tokyo.yywtaylor.cyou_ecc
# 若主站用 yywtaylor.cyou，需再申请一张或做 DNS 泛域名证书

server {
    listen 80;
    server_name yywtaylor.cyou www.yywtaylor.cyou;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name yywtaylor.cyou www.yywtaylor.cyou;

    # 按你 acme.sh 实际路径修改
    ssl_certificate     /root/.acme.sh/yywtaylor.cyou_ecc/fullchain.cer;
    ssl_certificate_key /root/.acme.sh/yywtaylor.cyou_ecc/yywtaylor.cyou.key;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
